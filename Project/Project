-- This queries JUST for TEST
SELECT * FROM Users;

-- All Benefitecal
SELECT u.full_name, u.role, b.family_members_count, b.poverty_score, b.last_received_date
FROM Users u
JOIN Beneficiary_Details b ON u.user_id = b.user_id;

-- All Warehouse
SELECT w.name AS warehouse_name, w.location, w.current_status, u.full_name AS supervisor
FROM Warehouses w
JOIN Users u ON w.supervisor_id = u.user_id;

-- All item in warehouse and category
SELECT i.name AS item_name, i.quantity_kg, i.expiry_date, w.name AS warehouse_name, f.category_name
FROM Inventory_Items i
JOIN Warehouses w ON i.warehouse_id = w.warehouse_id
JOIN Food_Categories f ON i.category_id = f.category_id;

-- all donor
SELECT donor_name, amount_value, donation_type, org_type
FROM Donations_Log;

-- all volunteer
SELECT u.full_name, v.skill_type, v.years_of_experience
FROM Users u
JOIN Volunteer_Skills v ON u.user_id = v.volunteer_id;

-- all driver
SELECT u.full_name AS driver_name, t.session_name, t.trainer_name, t.session_date
FROM Users u
JOIN Driver_Training dt ON u.user_id = dt.driver_id
JOIN Training_Session t ON dt.session_id = t.session_id
WHERE u.role = 'Driver';